# Copy to .env and fill in. Never commit .env.
# All keys are optional for public market data; required only for the features noted.

# ---- Kalshi (optional; required only for authenticated reads like portfolio) ----
# The market-data endpoints used by the universe pull are public and need none of these.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./keys/kalshi_private.pem
KALSHI_ENV=prod   # prod | demo

# ---- FRED (free key, required for economic-release forecaster) ----
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ---- Gmail SMTP (required for email alerts) ----
# Use a Gmail App Password (not your account password). 2FA must be enabled.
# https://support.google.com/accounts/answer/185833
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
ALERT_RECIPIENT=

# ---- Optional: override data/log paths ----
KALSHI_EDGE_DATA_DIR=./data
KALSHI_EDGE_CONFIG=./config/default.yaml
KALSHI_EDGE_LOG_LEVEL=INFO
